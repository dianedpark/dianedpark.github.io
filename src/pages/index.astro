---
const projects = [
  {
    type: "Technical writing",
    title: "Explaining a complex system clearly",
    description:
      "A plain-language explainer that makes a technical subject understandable without removing important nuance.",
  },
  {
    type: "Editing",
    title: "Before, after, and why",
    description:
      "An editing case study showing how I improved clarity, structure, consistency, and voice while preserving the writer’s intent.",
  },
  {
    type: "Quality assurance",
    title: "Investigating an ambiguous product issue",
    description:
      "A sanitized QA case study covering the problem, evidence, testing approach, findings, and final recommendation.",
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />
    <meta
      name="description"
      content="Diane Park’s technical writing, editing, and product quality portfolio."
    />
    <title>Diane Park | Technical Writing and Product Quality</title>
  </head>

  <body>
    <header class="site-header">
      <a class="name" href="/">Diane Park</a>

      <nav aria-label="Main navigation">
        <a href="#work">Work</a>
        <a href="#about">About</a>
        <a href="#contact">Contact</a>
      </nav>
    </header>

    <main>
      <section class="hero">
        <p class="eyebrow">Technical writing · Editing · Product quality</p>

        <h1>
          I make complex technical work clear without making it less accurate.
        </h1>

        <p class="introduction">
          My background spans technical communication, localization, product
          QA, and workflow automation. I care about clarity, consistency, and
          making sure the final artifact faithfully represents the underlying
          reality.
        </p>

        <a class="button" href="#work">View selected work</a>
      </section>

      <section class="section" id="work">
        <div class="section-heading">
          <p class="eyebrow">Selected work</p>
          <h2>How I think, edit, and investigate</h2>
        </div>

        <div class="project-grid">
          {
            projects.map((project) => (
              <article class="project-card">
                <p class="project-type">{project.type}</p>
                <h3>{project.title}</h3>
                <p>{project.description}</p>
                <a href="/">Case study coming soon →</a>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section about" id="about">
        <div>
          <p class="eyebrow">About</p>
          <h2>Accuracy is part of the user experience.</h2>
        </div>

        <div>
          <p>
            I have spent my career working between language, technology, and
            product quality. Whether I am editing an explanation, investigating
            unexpected software behavior, or improving a workflow, I begin with
            the same question: does this clearly and accurately represent what
            is true?
          </p>

          <p>
            I currently work across customer-facing software experiences,
            partnering with technical and creative teams to identify issues,
            communicate evidence, and improve quality.
          </p>
        </div>
      </section>

      <section class="section contact" id="contact">
        <p class="eyebrow">Contact</p>

        <h2>Let’s discuss technical communication and product quality.</h2>

        <p class="contact-introduction">
          You can reach me by email or connect with me on LinkedIn.
        </p>

        <div class="contact-links">
          <a
            class="contact-badge"
            href="mailto:d.dianepark@gmail.com"
            aria-label="Email Diane Park"
          >
            <svg
              aria-hidden="true"
              viewBox="0 0 24 24"
              width="20"
              height="20"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <rect x="3" y="5" width="18" height="14" rx="2"></rect>
              <path d="m3 7 9 6 9-6"></path>
            </svg>

            <span>d.dianepark@gmail.com</span>
          </a>

          <a
            class="contact-badge"
            href="https://www.linkedin.com/in/dianedpark/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="View Diane Park’s LinkedIn profile"
          >
            <svg
              aria-hidden="true"
              viewBox="0 0 24 24"
              width="20"
              height="20"
              fill="currentColor"
            >
              <path
                d="M6.5 8.3H3.2V19h3.3V8.3ZM4.85 3A1.92 1.92 0 1 0 4.85 6.84 1.92 1.92 0 0 0 4.85 3ZM19.8 12.86c0-3.22-1.72-4.72-4.02-4.72-1.85 0-2.68 1.02-3.15 1.74V8.3H9.34V19h3.29v-5.3c0-1.4.27-2.77 2.02-2.77 1.72 0 1.74 1.61 1.74 2.86V19h3.3l.11-6.14Z"
              />
            </svg>

            <span>LinkedIn</span>
          </a>
        </div>
      </section>
    </main>

    <footer>
      <p>© {new Date().getFullYear()} Diane Park</p>
    </footer>
  </body>
</html>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(html) {
    scroll-behavior: smooth;
  }

  :global(body) {
    margin: 0;
    background: #f7f6f2;
    color: #181818;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
    line-height: 1.65;
  }

  a {
    color: inherit;
  }

  .site-header {
    width: min(1120px, calc(100% - 40px));
    margin: 0 auto;
    padding: 28px 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .name {
    font-weight: 700;
    text-decoration: none;
  }

  nav {
    display: flex;
    gap: 24px;
  }

  nav a {
    font-size: 0.9rem;
    text-decoration: none;
  }

  nav a:hover {
    text-decoration: underline;
  }

  main {
    width: min(1120px, calc(100% - 40px));
    margin: 0 auto;
  }

  .hero {
    min-height: 72vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    max-width: 900px;
    padding: 80px 0 120px;
  }

  .eyebrow,
  .project-type {
    margin-bottom: 16px;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    max-width: 900px;
    margin-bottom: 32px;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(3rem, 8vw, 6.5rem);
    font-weight: 400;
    letter-spacing: -0.055em;
    line-height: 0.98;
  }

  h2 {
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2rem, 5vw, 3.8rem);
    font-weight: 400;
    letter-spacing: -0.035em;
    line-height: 1.05;
  }

  h3 {
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.65rem;
    font-weight: 400;
    line-height: 1.2;
  }

  .introduction {
    max-width: 690px;
    margin-bottom: 32px;
    font-size: 1.15rem;
  }

  .button {
    width: fit-content;
    padding: 12px 18px;
    border: 1px solid #181818;
    text-decoration: none;
  }

  .button:hover {
    background: #181818;
    color: #f7f6f2;
  }

  .section {
    padding: 110px 0;
    border-top: 1px solid #c9c7c1;
  }

  .section-heading {
    max-width: 700px;
    margin-bottom: 56px;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .project-card {
    min-height: 340px;
    padding: 28px;
    border: 1px solid #c9c7c1;
    display: flex;
    flex-direction: column;
  }

  .project-card a {
    margin-top: auto;
  }

  .about {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
  }

  .about p {
    max-width: 620px;
    font-size: 1.1rem;
  }

  .contact {
    max-width: 800px;
  }

  .contact-introduction {
    margin-bottom: 28px;
    font-size: 1.1rem;
  }

  .contact-links {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }

  .contact-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    border: 1px solid #181818;
    text-decoration: none;
    transition:
      background-color 180ms ease,
      color 180ms ease,
      transform 180ms ease;
  }

  .contact-badge:hover {
    background: #181818;
    color: #f7f6f2;
    transform: translateY(-1px);
  }

  .contact-badge svg {
    flex-shrink: 0;
  }

  footer {
    width: min(1120px, calc(100% - 40px));
    margin: 0 auto;
    padding: 40px 0;
    border-top: 1px solid #c9c7c1;
    font-size: 0.85rem;
  }

  @media (max-width: 760px) {
    .site-header {
      align-items: flex-start;
    }

    nav {
      gap: 12px;
      flex-direction: column;
    }

    .hero {
      min-height: auto;
      padding: 100px 0;
    }

    .project-grid,
    .about {
      grid-template-columns: 1fr;
    }

    .about {
      gap: 24px;
    }

    .project-card {
      min-height: 280px;
    }
  }
</style>